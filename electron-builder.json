{
  "appId": "com.hospital.surgery-scheduler-client",
  "productName": "医院手术排班系统",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": [
    "main.js",
    "preload.js",
    "package.json",
    "!client/**/*",
    "!server/**/*",
    "!data/**/*",
    "!node_modules/**/*"
  ],
  "mac": {
    "category": "public.app-category.medical",
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "build/icon.png",
    "hardenedRuntime": false,
    "gatekeeperAssess": false
  },
  "dmg": {
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ],
    "window": {
      "width": 540,
      "height": 400
    }
  },
  "win": {
    "target": ["nsis", "portable"],
    "icon": "build/icon.ico"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "icon": "build/icons",
    "category": "Office"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "publish": null
}
